generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum LoginProvider {
  EMAIL
  GOOGLE
}

model User {
  id            String        @id @unique @default(uuid()) @db.Uuid
  name          String
  email         String        @unique
  password      String?
  salt          String?
  role          UserRole      @default(USER)
  loginProvider LoginProvider @default(EMAIL)

  hasNotifications Boolean @default(false)
  isEmailVerified  Boolean @default(false)

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects      Project[]
  userAccesses  UserAccess[]
  actorLogs     Log[]        @relation("ActorLogs")
  targetLogs    Log[]        @relation("TargetLogs")
  createdNodes  CanvasNode[]
  createdTasks  Task[]

  @@index([name])
  @@index([email])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProjectInvitation {
  id    String @id @unique @default(uuid()) @db.Uuid
  email String

  status       InvitationStatus @default(PENDING)
  accessLevel  UserAccessLevel  @default(VIEWER)

  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([projectId])
  @@index([status])
  @@unique([projectId, email])
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

model Project {
  id          String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  userId      String  @db.Uuid

  user User @relation(fields: [userId], references: [id])

  visibility ProjectVisibility @default(PRIVATE)

  invitations ProjectInvitation[]
  canvasNodes CanvasNode[]
  canvasEdges CanvasEdge[]

  taskBoard TaskBoard?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name, userId])
  @@index([name])
  @@index([userId])
}

enum NodeIntent {
  ACTION_ITEM
  DECISION
  OPEN_QUESTION
  REFERENCE
  UNCLASSIFIED
}

enum NodeRole {
  LEAD
  CONTRIBUTOR
  VIEWER
}

model CanvasNode {
  id          String      @id @default(uuid()) @db.Uuid
  projectId   String      @db.Uuid
  project     Project     @relation(fields: [projectId], references: [id])

  type        String
  positionX   Float
  positionY   Float
  width       Float       @default(200)
  height      Float       @default(150)
  data        Json

  intent      NodeIntent  @default(UNCLASSIFIED)
  lockedToRole NodeRole?

  createdById String      @db.Uuid
  createdBy   User        @relation(fields: [createdById], references: [id])

  tasks       Task[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([projectId])
  @@index([intent])
}
model CanvasEdge {
  id        String  @id @unique @default(uuid()) @db.Uuid
  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])

  sourceNodeId String
  targetNodeId String
  sourceHandle String?
  targetHandle String?
  label        String?
  color        String  @default("#9ca3af")

  createdById String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([projectId])
}

enum UserAccessLevel {
  VIEWER
  EDITOR
  COMMENTATOR
  LEAD
}

enum UserAccessType {
  PROJECT
  NODE
}

model UserAccess {
  id String @id @unique @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  entityId   String         @db.Uuid
  entityType UserAccessType @default(PROJECT)

  accessLevel UserAccessLevel @default(VIEWER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, entityType, entityId])
  @@index([userId])
  @@index([entityType, entityId])
}

enum LogLevel {
  INFO
  WARN
  ERROR
}

enum LogEntityType {
  PROJECT
  NODE
  PROJECT_INVITATION
  USER_ACCESS
  USER
}

model Log {
  id      String       @id @unique @default(uuid()) @db.Uuid
  level   LogLevel     @default(INFO)
  action  String
  message String

  entityId   String        @db.Uuid
  entityType LogEntityType

  actorUserId String? @db.Uuid
  actorUser   User?   @relation("ActorLogs", fields: [actorUserId], references: [id])

  targetUserId String? @db.Uuid
  targetUser   User?   @relation("TargetLogs", fields: [targetUserId], references: [id])

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([createdAt])
}

model TaskBoard {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @unique @db.Uuid
  project   Project   @relation(fields: [projectId], references: [id])
  tasks     Task[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Task {
  id           String     @id @default(uuid()) @db.Uuid
  taskBoardId  String     @db.Uuid
  taskBoard    TaskBoard  @relation(fields: [taskBoardId], references: [id])

  canvasNodeId String     @db.Uuid
  canvasNode   CanvasNode @relation(fields: [canvasNodeId], references: [id])

  createdById  String     @db.Uuid
  createdBy    User       @relation(fields: [createdById], references: [id])

  title        String
  description  String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([taskBoardId])
  @@index([canvasNodeId])
}