generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
}

enum LoginProvider {
  EMAIL
  GOOGLE
}

model User {
  id            String        @id @unique @default(uuid()) @db.Uuid
  name          String
  email         String        @unique
  password      String?
  salt          String?
  role          UserRole      @default(USER)
  loginProvider LoginProvider @default(EMAIL)

  hasNotifications Boolean @default(false)
  isEmailVerified  Boolean @default(false)

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projects     Project[]
  userAccesses UserAccess[]

  @@index([name])
  @@index([email])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model ProjectInvitation {
  id    String @id @unique @default(uuid()) @db.Uuid
  email String

  status InvitationStatus @default(PENDING)

  projectId String  @db.Uuid
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([email])
  @@index([projectId])
  @@index([status])
}

enum ProjectAccessLevel {
  VIEWER
  EDITOR
  COMMENTATOR
  LEAD
}

enum ProjectVisibility {
  PUBLIC
  PRIVATE
}

model Project {
  id          String  @id @unique @default(uuid()) @db.Uuid
  name        String
  description String?
  userId      String  @db.Uuid

  user User @relation(fields: [userId], references: [id])

  visibility ProjectVisibility @default(PRIVATE)

  invitations ProjectInvitation[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([name, userId])
  @@index([name])
  @@index([userId])
}

enum UserAccessLevel {
  VIEWER
  EDITOR
  COMMENTATOR
  LEAD
}

enum UserAccessType {
  PROJECT
  NODE
}

model UserAccess {
  id String @id @unique @default(uuid()) @db.Uuid

  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  entityId   String         @db.Uuid
  entityType UserAccessType @default(PROJECT)

  accessLevel UserAccessLevel @default(VIEWER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, entityType])
  @@index([userId])
}
